{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["bun-types"],
    "jsx": "react-jsx",
    "rootDir": "src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"]
}
